{
  "$jsonSchema": {
    "bsonType": "object",
    "required": ["name"],
    "preview": ["display_name", "type", "tier"],
    "sort": "name",
    "properties": {
      "name": {
        "bsonType": "string",
        "label": "Key",
        "description": "Internal key for the title (lowercase_with_underscores)"
      },
      "display_name": {
        "bsonType": "string",
        "label": "Display Name",
        "description": "The display name of the title (e.g. 'the Brave')"
      },
      "type": {
        "bsonType": "enum",
        "label": "Type",
        "description": "Whether this is a positive or negative title",
        "enum": ["positive", "negative"],
        "default": "positive"
      },
      "tier": {
        "bsonType": "number",
        "label": "Tier",
        "description": "The tier of the title (1-3)"
      },
      "modifiers": {
        "bsonType": "object",
        "label": "Modifiers",
        "description": "The modifiers this title provides (e.g. nation_trade_slots: 1)"
      }
    }
  }
}
